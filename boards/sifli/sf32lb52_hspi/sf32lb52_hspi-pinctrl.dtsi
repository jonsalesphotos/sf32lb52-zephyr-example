#include <zephyr/dt-bindings/pinctrl/sf32lb52x-pinctrl.h>

&pinctrl {
	usart1_default: usart1_default {
		group1 {
			pinmux = <PA19_USART1_TXD>;
		};

		group2 {
			pinmux = <PA18_USART1_RXD>;
			input-enable;
			bias-pull-up;
		};
	};

	/* Touch-panel I2C (FT6146): SDA PA_33, SCL PA_37 per Huangshan Pi netlist. */
	i2c1_default: i2c1_default {
		group1 {
			pinmux = <PA33_I2C1_SDA>, <PA37_I2C1_SCL>;
			input-enable;
		};
	};

	/* Charger I2C (net I2C2): SDA PA_11, SCL PA_10.
	 * NOTE: PA_10 is also wired to the audio PA enable; resolve before use.
	 */
	i2c2_default: i2c2_default {
		group1 {
			pinmux = <PA11_I2C2_SDA>, <PA10_I2C2_SCL>;
			input-enable;
		};
	};

	/* On-board sensor I2C (net I2C3): SDA PA_39, SCL PA_40. */
	i2c3_default: i2c3_default {
		group1 {
			pinmux = <PA39_I2C3_SDA>, <PA40_I2C3_SCL>;
			input-enable;
		};
	};

	spi1_default: spi1_default {
		/* PA_29 (TF-card CS) is intentionally NOT muxed as SPI1_CS: it is
		 * driven as a GPIO through the spi1 cs-gpios property so the SD
		 * protocol can hold CS across multi-transfer commands.
		 */
		group1 {
			pinmux = <PA24_SPI1_DIO>, <PA28_SPI1_CLK>;
			input-enable;
			input-schmitt-enable;
		};

		group2 {
			pinmux = <PA25_SPI1_DI>;
			input-enable;
			input-schmitt-enable;
			bias-pull-up;
		};
	};

	/* Vibrator control: PA_20_VIB_PWM -> GPTIM2 CH1. */
	vib_pwm_default: vib_pwm_default {
		group1 {
			pinmux = <PA20_GPTIM2_CH1>;
		};
	};

	lcdc_qspi_default: lcdc_qspi_default {
		group1 {
			pinmux = <PA02_LCDC1_SPI_TE>,
				 <PA03_LCDC1_SPI_CS>,
				 <PA04_LCDC1_SPI_CLK>,
				 <PA05_LCDC1_SPI_DIO0>,
				 <PA06_LCDC1_SPI_DIO1>,
				 <PA07_LCDC1_SPI_DIO2>,
				 <PA08_LCDC1_SPI_DIO3>;
			input-enable;
		};
	};

	/* MPI1 OPI PSRAM pinmux configuration */
	mpi1_default: mpi1_default {
		group1 {
			pinmux = <SA01_MPI1_DIO0>, <SA02_MPI1_DIO1>,
				 <SA03_MPI1_DIO2>, <SA04_MPI1_DIO3>,
				 <SA08_MPI1_DIO4>, <SA09_MPI1_DIO5>,
				 <SA10_MPI1_DIO6>, <SA11_MPI1_DIO7>,
				 <SA12_MPI1_DQSDM>;
			bias-pull-down;
			input-enable;
			input-schmitt-enable;
			slew-rate=<1>;
		};

		group2 {
			pinmux = <SA07_MPI1_CLK>, <SA05_MPI1_CS>;
			input-enable;
			input-schmitt-enable;
			slew-rate=<1>;
		};

		/* SA00 and SA06 are power supply pins, configure as analog */
		group3 {
			pinmux = <SA00_ANALOG>, <SA06_ANALOG>;
		};
	};

	lxt32_default: lxt32_default {
		group1 {
			pinmux = <PA22_XTAL32K_XI>, <PA23_XTAL32K_XO>;
			input-enable;
		};
	};

	/*
	 * Intentionally empty: only the internal VBAT channel (7) is used on
	 * this board and it has no external pad. Every external GPADC-capable
	 * pad (PA_28..PA_34 = CH0..CH6) already serves another board function.
	 * The gpadc binding requires a pinctrl-0, so an empty state is given.
	 */
	gpadc_default: gpadc_default {
	};
};

&pmuc_clk {
	pinctrl-0 = <&lxt32_default>;
	pinctrl-names = "default";
};
