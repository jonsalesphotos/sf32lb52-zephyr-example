/dts-v1/;

#include <sifli/sf32lb52x.dtsi>
#include <sifli/sf32lb52x-ram012.dtsi>
#include <zephyr/dt-bindings/dma/sf32lb52x-dma.h>
#include <zephyr/dt-bindings/gpio/gpio.h>
#include <zephyr/dt-bindings/i2c/i2c.h>
#include <zephyr/dt-bindings/input/input-event-codes.h>
#include <zephyr/dt-bindings/led/led.h>
#include <zephyr/dt-bindings/pwm/pwm.h>

#include "sf32lb52_hspi-pinctrl.dtsi"

/ {
	model = "LCKFB SF32LB52-HSPI (Huangshan Pi)";
	compatible = "sifli,sf32lb52-hspi";

	/*
	 * This initial board file inherits the SF32LB52-DevKit-LCD device tree.
	 * Verify GPIO, display, audio, and storage pin mappings against the
	 * Huangshan Pi schematic before relying on enabled peripherals.
	 */

	chosen {
		zephyr,flash = &py25q128ha;
		zephyr,flash-controller = &mpi2;
		zephyr,code-partition = &code;
		zephyr,console = &usart1;
		zephyr,shell-uart = &usart1;
		zephyr,crc = &crc;
		zephyr,entropy = &trng;
		zephyr,bt-hci = &mailbox;
		zephyr,display = &co5300;
	};

	buttons {
		compatible = "gpio-keys";

		key1: key1 {
			label = "KEY1";
			/*
			 * PA_34 = VBAT via SW1 (active-high when pressed).
			 *
			 * HARDWARE SIDE-EFFECT (netlist verified):
			 * PA_34 also drives Q1 gate → CHG_INT (AW32001 INT pin).
			 * Pressing KEY1 pulls CHG_INT LOW via Q1. Per AW32001E
			 * datasheet, INT LOW can toggle shipping mode (disconnect
			 * battery from system). Short press = normal key; long
			 * press (~seconds) = hardware power-cycle via charger IC.
			 * Do NOT drive PA_34 high for extended periods in firmware.
			 */
			gpios = <&gpioa_32_44 2 GPIO_ACTIVE_HIGH>;
			zephyr,code = <INPUT_KEY_1>;
		};

		key2: key2 {
			label = "KEY2";
			/* SW2 / function key = PA_43 (netlist PA_43_KEY2 -> SW2;
			 * SDK CONFIG_BSP_KEY2_PIN=43). PA_11 is the charger I2C2 SDA.
			 */
			gpios = <&gpioa_32_44 11 GPIO_ACTIVE_HIGH>;
			zephyr,code = <INPUT_KEY_2>;
		};
	};

	/*
	 * LED inventory (schematic / netlist verified):
	 * - LED1: Red 0603 power indicator, hard-wired between VBUS_5V (via R6
	 *   4.7kΩ) and GND. Always on when USB is plugged — NOT GPIO-controllable.
	 * - LED3 (WS2812B-2020): RGB smart LED on PA_32, 1-Wire protocol. Modeled
	 *   as led_strip below (currently disabled).
	 *
	 * There is NO GPIO-controlled LED on PA_26. PA_26 drives the VCC_3V3
	 * load-switch enable (ETA5055V330DS2F U4) — see regulator-vcc3v3 below.
	 */

	aliases {
		codec0 = &audcodec;
		sw0 = &key1;
		sw1 = &key2;
		rtc = &rtc;
		watchdog0 = &wdt;
	};

	psram: psram@60000000 {
		compatible = "zephyr,memory-region";
		reg = <0x60000000 DT_SIZE_M(8)>;
		zephyr,memory-region = "PSRAM";
		zephyr,memory-attr = <(DT_MEM_ARM(ATTR_MPU_RAM))>;
	};

	/*
	 * Power tree (schematic / netlist verified, 2026-06-28):
	 *
	 *   USB_VBUS_5V ── LP5305AQVF (U17, OVP/OCP) ── VBUS_5V
	 *                                                    │
	 *   VBAT_S  ─────────────────────────────────────────┤
	 *                                                    ▼
	 *                    AW32001ECSR (U3, charger, I2C2 PA_10/PA_11)
	 *                    ├─ CHG_INT = U3.B2/Q1.3/R5.1, pulled low via Q1 by PA_34
	 *                    ├─ PA_44 = VBUS_DET divider, not AW32001 INT
	 *                    ▼
	 *                  VSYS_S (VSYS)
	 *                    │
	 *       ┌────────────┼────────────────────┐
	 *       ▼            ▼                    ▼
	 *   NS4150B      SF32LB52              LP5240HVF
	 *   (PA_42)       主控                 (U2, PA_38)
	 *   功放           │                     │
	 *                  └─ LDO3_3V3 / VDD33_VOUT2
	 *                     (module pin 17, net VDD33_VOUT)
	 *                       ├─ R51 0Ω → LED3 WS2812B VDD (data PA_32)
	 *                       └─ R36 5.1Ω → vibrator supply (PWM PA_20)
	 *                                        │
	 *                                        ▼
	 *                                      VSYS_1
	 *                                        │
	 *       ┌────────────────┬───────────────┤
	 *       ▼                ▼               ▼
	 *   屏幕 FPC        ETA5055V330DS2F   ETA5055V330DS2F
	 *   (VSYS_1直供)    (U4, PA_26)       (U15, PA_30)
	 *                       │                 │
	 *                       ▼                 ▼
	 *                   VCC_3V3_S          GS_3V3
	 *                 (TP/SPI/SD卡)      (传感器总线)
	 *
	 * Power-on sequence (SDK bsp_power.c):
	 *   PA_38 (VSYS_1) → PA_26 (VCC_3V3) → PA_30 (GS_3V3)
	 *   Followed by ~500 µs settle before sensor/charger I2C is usable.
	 *
	 * Regulator strategy:
	 *   vsys_en  — regulator-always-on (system rail, never off)
	 *   vcc_3v3  — regulator-always-on (peripheral rail, always on)
	 *   gs_3v3   — regulator-boot-off  (sensor bus, app-managed)
	 * All enable GPIOs are active-high, default-off at reset.
	 * regulator-boot-on requires CONFIG_REGULATOR to auto-enable at boot.
	 */
	vsys_en: regulator-vsys {
		compatible = "regulator-fixed";
		regulator-name = "vsys-en";
		/* PA_38 → LP5240HVF (U2) EN. System VSYS_1 rail — never turn off. */
		enable-gpios = <&gpioa_32_44 6 GPIO_ACTIVE_HIGH>;
		regulator-boot-on;
	};

	vcc_3v3: regulator-vcc3v3 {
		compatible = "regulator-fixed";
		regulator-name = "vcc-3v3";
		/* PA_26 → ETA5055V330DS2F (U4) EN. Powers VCC_3V3_S rail:
		 * touch-panel I2C1 pull-ups, SPI1/SD-card VDD, etc.
		 * regulator-always-on: fundamental peripheral rail, always on.
		 */
		enable-gpios = <&gpioa_00_31 26 GPIO_ACTIVE_HIGH>;
		regulator-always-on;
	};

	gs_3v3: regulator-gs3v3 {
		compatible = "regulator-fixed";
		regulator-name = "gs-3v3";
		/* PA_30 → ETA5055V330DS2F (U15) EN. Powers the sensor bus
		 * (I2C3: LSM6DS3TR-C, MMC5603NJ, LTR-303ALS-01).
		 * regulator-boot-off: default off. Application must call
		 *   regulator_enable(DEVICE_DT_GET(DT_NODELABEL(gs_3v3)));
		 * then wait ~500 µs before accessing sensors on I2C3.
		 * Sensor drivers (lsm6dsl/mmc56x3/ltr329) do not have
		 * built-in vin-supply support, so regulator management is
		 * explicit at the application level.
		 */
		enable-gpios = <&gpioa_00_31 30 GPIO_ACTIVE_HIGH>;
		regulator-boot-off;
	};

	/*
	 * On-board WS2812B-2020 RGB smart LED (LED3) on PA_32.
	 * LED3 VDD is VDD33_VOUT from SF32LB52 LDO3_3V3 via R51.
	 * 1-Wire protocol (NZR), bit-bang GPIO driver.
	 * Reset-delay / timing are placeholders; tune on bring-up.
	 * Disabled until brought up.
	 */
	led_strip: led-strip {
		compatible = "worldsemi,ws2812-gpio";
		gpios = <&gpioa_32_44 0 GPIO_ACTIVE_HIGH>;
		chain-length = <1>;
		color-mapping = <LED_COLOR_ID_GREEN
				 LED_COLOR_ID_RED
				 LED_COLOR_ID_BLUE>;
		reset-delay = <280>;
		status = "disabled";
	};

	/*
	 * Vibrator motor:
	 *   - supply: VDD33_VOUT from SF32LB52 LDO3_3V3 via R36
	 *   - control: PA_20_VIB_PWM, routed as GPTIM2 CH1
	 *
	 * Keep disabled by default to avoid unintended vibration at boot. Enable
	 * this node together with &gptim2 / &gptim2_pwm during vibrator bring-up.
	 */
	pwm_vibrator: pwm-vibrator {
		compatible = "pwm-leds";
		status = "disabled";

		vibrator: vibrator {
			label = "VIBRATOR";
			pwms = <&gptim2_pwm 0 PWM_MSEC(5) PWM_POLARITY_NORMAL>;
		};
	};
};

&cpu0 {
	clock-frequency = <DT_FREQ_M(240)>;
};

&hxt48 {
	status = "okay";
};

&lxt32 {
	status = "okay";
};

&rcc_clk {
	status = "okay";

	sifli,hdiv = <1>;
	sifli,pdiv1 = <1>;
	sifli,pdiv2 = <6>;
	sifli,sys-clk-src = "dll1";
	sifli,mpi1-clk-src = "dll2";

	dll1 {
		status = "okay";
		clock-frequency = <DT_FREQ_M(240)>;
	};

	dll2 {
		status = "okay";
		clock-frequency = <DT_FREQ_M(288)>;
	};
};

&rcc_rst {
	status = "okay";
};

&gpioa_00_31 {
	status = "okay";
};

&gpioa_32_44 {
	status = "okay";
};

&dmac {
	status = "okay";
};

&ldo1_1v8 {
	regulator-boot-on;
	status = "okay";
};

&ldo3_3v3 {
	/*
	 * SF32LB52 internal 3.3 V LDO output:
	 *   LDO3_3V3 / VDD33_VOUT2 (module pin 17) -> board net VDD33_VOUT.
	 * It powers LED3 (WS2812B) and the vibrator motor supply path.
	 */
	regulator-name = "vdd33-vout";
	regulator-boot-on;
	status = "okay";
};

&mpi1 {
	compatible = "sifli,sf32lb-mpi-opi-psram";
	/* SF32LB525UC6 has 8MB internal OPI PSRAM */
	reg = <0x50041000 0x1000>, <0x60000000 DT_SIZE_M(8)>;
	reg-names = "ctrl", "psram";
	pinctrl-0 = <&mpi1_default>;
	pinctrl-names = "default";
	power-supply = <&ldo1_1v8>;
	status = "okay";
};

&mpi2 {
	compatible = "sifli,sf32lb-mpi-qspi-nor";
	dmas = <&dmac 0 SF32LB52X_DMA_REQ_MPI2 SF32LB_DMA_PL_MEDIUM>;
	sifli,psclr = <0>;
	sifli,lines = <4>;
	status = "okay";

	py25q128ha: flash@0 {
		compatible = "puya,py25q128ha", "jedec,qspi-nor";
		reg = <0x0>;
		size = <DT_SIZE_M(128)>;
		quad-enable-requirements = "S2B1v1";

		partitions {
			compatible = "fixed-partitions";
			#address-cells = <1>;
			#size-cells = <1>;

			ptable: partition@0 {
				label = "ptable";
				reg = <0x0 DT_SIZE_K(64)>;
			};

			code: partition@10000 {
				label = "code";
				reg = <0x10000 DT_SIZE_K(16320)>;
			};
		};
	};
};

&pinctrl {
	status = "okay";
};

&usart1 {
	status = "okay";
	current-speed = <1000000>;
	pinctrl-0 = <&usart1_default>;
	pinctrl-names = "default";
};

&audcodec {
	dmas = <&dmac 1 SF32LB52X_DMA_REQ_AUDAC_CH0 SF32LB_DMA_PL_HIGH>,
	       <&dmac 4 SF32LB52X_DMA_REQ_AUDADC_CH0 SF32LB_DMA_PL_HIGH>;
	dma-names = "tx", "rx";
	/* Class-D PA enable = PA_42 (netlist PA_42 -> U6; SDK
	 * CONFIG_AW8155_GPIO_PIN=42, active high). PA_10 is the charger I2C2 SCL.
	 */
	pa-power-gpios = <&gpioa_32_44 10 GPIO_ACTIVE_HIGH>;
	status = "okay";
};

&wdt {
	status = "okay";
};

&rtc {
	status = "okay";
};

&gptim2 {
	/*
	 * PA_20_VIB_PWM = GPTIM2 CH1. The PWM controller is described here but
	 * remains disabled until the vibrator function is intentionally enabled.
	 */
	gptim2_pwm: pwm {
		pinctrl-0 = <&vib_pwm_default>;
		pinctrl-names = "default";
		status = "disabled";
	};
};

&i2c1 {
	status = "okay";
	pinctrl-0 = <&i2c1_default>;
	pinctrl-names = "default";
	clock-frequency = <I2C_BITRATE_FAST>;

	ft6146: ft6146@38 {
		/* Capacitive touch panel (FT6146) on the LCD FPC. INT PA_41,
		 * RST PA_09 per the screen netlist. Disabled until brought up.
		 */
		compatible = "focaltech,ft6146";
		reg = <0x38>;
		int-gpios = <&gpioa_32_44 9 GPIO_ACTIVE_LOW>;
		reset-gpios = <&gpioa_00_31 9 GPIO_ACTIVE_LOW>;
		status = "disabled";
	};
};

&i2c3 {
	/* On-board sensor bus: LSM6DS3TR-C IMU, MMC5603NJ magnetometer,
	 * LTR-303ALS-01 ambient light. Powered by the GS_3V3 rail (PA_30).
	 */
	status = "okay";
	pinctrl-0 = <&i2c3_default>;
	pinctrl-names = "default";
	clock-frequency = <I2C_BITRATE_FAST>;

	lsm6dsl: lsm6dsl@6a {
		/* LSM6DS3TR-C (U13) is register-compatible with LSM6DSL
		 * (WHO_AM_I 0x6A). SA0 is tied low -> I2C address 0x6A.
		 * Disabled until brought up (enable with the lsm6dsl driver).
		 */
		compatible = "st,lsm6dsl";
		reg = <0x6a>;
		irq-gpios = <&gpioa_00_31 31 GPIO_ACTIVE_HIGH>;
		status = "disabled";
	};

	mmc56x3: mmc56x3@30 {
		/* MMC5603NJ (U14), fixed I2C address 0x30. Disabled until brought up. */
		compatible = "memsic,mmc56x3";
		reg = <0x30>;
		status = "disabled";
	};

	ltr303: ltr303@29 {
		/* LTR-303ALS-01 (U16), I2C address 0x29. No dedicated upstream
		 * Zephyr driver; liteon,ltr329 is register-similar but unverified,
		 * so this node is left disabled until a driver is confirmed.
		 */
		compatible = "liteon,ltr329";
		reg = <0x29>;
		status = "disabled";
	};
};

&i2c2 {
	/* Charger control bus (net I2C2): SCL PA_10, SDA PA_11. With the audio PA
	 * moved to PA_42 and KEY2 to PA_43, these pins are now free, so the bus is
	 * enabled; the charger child stays disabled until its driver is brought up.
	 */
	status = "okay";
	pinctrl-0 = <&i2c2_default>;
	pinctrl-names = "default";
	clock-frequency = <I2C_BITRATE_FAST>;

	charger: charger@49 {
		/* AW32001 (U3) linear charger, address 0x49 (netlist + SDK confirmed).
		 * Placeholder compatible - no upstream Zephyr driver yet.
		 * AW32001 INT is net CHG_INT (U3.B2/Q1.3/R5.1) and is not directly
		 * connected to an MCU GPIO. PA_34 can pull CHG_INT low through Q1;
		 * PA_44 is a separate VBUS_DET divider and must not be modeled as
		 * charger int-gpios.
		 */
		compatible = "awinic,aw32001";
		reg = <0x49>;
		status = "disabled";
	};
};

&crc {
	status = "okay";
};

&crypto {
	status = "okay";
};

temp_sensor: &tsen {
	status = "okay";
};

&trng {
	status = "okay";
};

&mailbox {
	status = "okay";
};

&spi1 {
	status = "okay";
	pinctrl-0 = <&spi1_default>;
	pinctrl-names = "default";
};

&efuse {
	status = "okay";
};

&lcdc {
	status = "okay";

	mipi_dbi: mipi-dbi {
		status = "okay";
		#address-cells = <1>;
		#size-cells = <0>;
		pinctrl-0 = <&lcdc_qspi_default>;
		pinctrl-names = "default";

		co5300: display@0 {
			compatible = "chipone,co5300-qspi";
			reg = <0>;
			reset-gpios = <&gpioa_00_31 0 GPIO_ACTIVE_LOW>;
			/*
			 * No host AVDD-enable GPIO on the Huangshan Pi: PA_37
			 * (the inherited DevKit-LCD avdd pin) is the touch-panel
			 * I2C1 SCL here, and the AMOLED AVDD is generated by the
			 * screen's own power IC from VCC_3V3.
			 */
			width = <390>;
			height = <450>;
			mipi-max-frequency = <50000000>;
			mipi-mode = "MIPI_DBI_MODE_QSPI";
		};
	};
};
